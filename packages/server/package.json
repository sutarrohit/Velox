{
    "name": "@velox/server",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "lint": "eslint . --max-warnings 0",
        "build": "tsc && tsc-alias && node -e \"require('fs').cpSync('prisma', 'dist/prisma', {recursive: true})\"",
        "start": "bun run dist/src/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "cdk:synth": "cdk synth",
        "cdk:deploy": "cdk deploy --require-approval never",
        "cdk:diff": "cdk diff",
        "cdk:destroy": "cdk destroy"
    },
    "exports": {
        ".": "./dist/src/index.js"
    },
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.4.0",
        "@google/genai": "^1.43.0",
        "@hono/zod-openapi": "^1.2.1",
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "@scalar/hono-api-reference": "^0.9.40",
        "@velox/typescript-config": "*",
        "axios": "^1.13.6",
        "dotenv": "^17.2.4",
        "dotenv-expand": "^12.0.3",
        "hono": "^4.11.9",
        "hono-openapi": "^1.2.0",
        "hono-pino": "^0.10.3",
        "hono-rate-limiter": "^0.5.3",
        "node-cache": "^5.1.2",
        "pg": "^8.18.0",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "stoker": "^2.0.1",
        "tsc-alias": "^1.8.16",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/node": "^25.2.0",
        "@types/pg": "^8.16.0",
        "@velox/eslint-config": "*",
        "@vitest/coverage-v8": "3.2.4",
        "prisma": "^7.3.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^3.0.0"
    }
}
